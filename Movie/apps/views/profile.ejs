<!DOCTYPE html>
<html class="dark" lang="vi">
<head>
    <%- include('partical/header'); %>
    <title><%= title %></title>
</head>
<body class="bg-background-dark text-white font-display antialiased selection:bg-primary selection:text-white">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
        <%- include('partical/menu'); %>
        
        <main class="flex-grow pt-24 pb-12 px-4 sm:px-6 lg:px-8 relative z-10">
            <!-- Background Elements -->
            <div class="absolute top-0 left-1/4 w-96 h-96 bg-accent-purple/20 rounded-full blur-[128px] pointer-events-none -z-10"></div>
            <div class="absolute top-20 right-1/4 w-96 h-96 bg-primary/10 rounded-full blur-[128px] pointer-events-none -z-10"></div>

            <div class="max-w-[90rem] mx-auto">
                <h1 class="text-3xl md:text-4xl font-bold mb-8 flex items-center gap-3">
                    <span class="w-1.5 h-8 bg-primary rounded-full"></span>
                    Hồ sơ cá nhân
                </h1>

                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                    <!-- Left Column: Avatar & Quick Stats -->
                    <div class="lg:col-span-3 flex flex-col gap-6">
                        <div class="glass-panel p-6 rounded-2xl border border-white/5 flex flex-col items-center text-center relative overflow-hidden group">
                            <div class="absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            
                            <div class="relative w-32 h-32 mb-4">
                                <div class="w-full h-full rounded-full bg-white/10 flex items-center justify-center ring-4 ring-white/10 shadow-2xl">
                                    <span class="text-5xl font-bold text-white select-none">
                                        <%= (user.email && user.email.charAt(0).toUpperCase()) || 'U' %>
                                    </span>
                                </div>
                                <button class="absolute bottom-0 right-0 p-2 rounded-full bg-surface-light border border-white/10 text-white hover:bg-primary transition-colors shadow-lg" title="Đổi ảnh đại diện">
                                    <span class="material-symbols-outlined text-[18px]">photo_camera</span>
                                </button>
                            </div>

                            <h2 class="text-xl font-bold text-white mb-1"><%= user.name %></h2>
                            <p class="text-sm text-gray-400 mb-4"><%= user.email %></p>
                            
                            <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-semibold text-gray-300">
                                <%= user.role === 'admin' ? 'Quản trị viên' : 'Thành viên' %>
                            </span>
                        </div>

                        <div class="glass-panel p-6 rounded-2xl border border-white/5">
                            <h3 class="font-bold text-lg mb-4 text-white">Thống kê</h3>
                            <div class="space-y-4">
                                <div class="flex justify-between items-center">
                                    <span class="text-gray-400 text-sm">Đã xem</span>
                                    <span class="font-bold text-white"><%= typeof watchHistory !== 'undefined' ? watchHistory.length : 0 %> phim</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-gray-400 text-sm">Yêu thích</span>
                                    <span class="font-bold text-white"><%= typeof wishlist !== 'undefined' ? wishlist.length : 0 %> phim</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-gray-400 text-sm">Bình luận</span>
                                    <span class="font-bold text-white">0</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Middle Column: Details & Settings -->
                    <div class="lg:col-span-6 flex flex-col gap-6">
                        <div class="glass-panel p-8 rounded-2xl border border-white/5">
                            <div class="flex justify-between items-center mb-6">
                                <h3 class="font-bold text-xl text-white flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">person</span>
                                    Thông tin tài khoản
                                </h3>
                                <button class="text-sm text-primary hover:text-white transition-colors font-medium">
                                    Chỉnh sửa
                                </button>
                            </div>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Họ và tên</label>
                                    <div class="p-3 rounded-lg bg-white/5 border border-white/10 text-gray-200 font-medium">
                                        <%= user.name %>
                                    </div>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Email</label>
                                    <div class="p-3 rounded-lg bg-white/5 border border-white/10 text-gray-200 font-medium">
                                        <%= user.email %>
                                    </div>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Số điện thoại</label>
                                    <div class="p-3 rounded-lg bg-white/5 border border-white/10 text-gray-400 italic">
                                        Chưa cập nhật
                                    </div>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Ngày tham gia</label>
                                    <div class="p-3 rounded-lg bg-white/5 border border-white/10 text-gray-200 font-medium">
                                        2024
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="glass-panel p-8 rounded-2xl border border-white/5">
                            <h3 class="font-bold text-xl text-white mb-6 flex items-center gap-2">
                                <span class="material-symbols-outlined text-accent-blue">settings</span>
                                Cài đặt & Bảo mật
                            </h3>
                            
                            <div class="space-y-4">
                                <a href="#" class="flex items-center justify-between p-4 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5 hover:border-white/20 transition-all group">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-gray-300 group-hover:text-white group-hover:bg-primary/20 transition-colors">
                                            <span class="material-symbols-outlined">lock</span>
                                        </div>
                                        <div>
                                            <h4 class="font-bold text-white group-hover:text-primary transition-colors">Đổi mật khẩu</h4>
                                            <p class="text-sm text-gray-400">Cập nhật mật khẩu để bảo vệ tài khoản</p>
                                        </div>
                                    </div>
                                    <span class="material-symbols-outlined text-gray-500 group-hover:text-white">chevron_right</span>
                                </a>

                                <a href="#" class="flex items-center justify-between p-4 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5 hover:border-white/20 transition-all group">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-gray-300 group-hover:text-white group-hover:bg-accent-blue/20 transition-colors">
                                            <span class="material-symbols-outlined">history</span>
                                        </div>
                                        <div>
                                            <h4 class="font-bold text-white group-hover:text-accent-blue transition-colors">Lịch sử xem</h4>
                                            <p class="text-sm text-gray-400">Quản lý lịch sử xem phim của bạn</p>
                                        </div>
                                    </div>
                                    <span class="material-symbols-outlined text-gray-500 group-hover:text-white">chevron_right</span>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Wishlist -->
                    <div class="lg:col-span-3 flex flex-col gap-6">
                        <div class="glass-panel p-8 rounded-2xl border border-white/5 h-full">
                            <div class="flex justify-between items-center mb-6">
                                <h3 class="font-bold text-xl text-white flex items-center gap-2">
                                    <span class="material-symbols-outlined text-accent-blue">favorite</span>
                                    Phim yêu thích
                                </h3>
                                <a href="#" class="text-sm text-accent-blue hover:text-white transition-colors font-medium">Quản lý</a>
                            </div>

                            <div class="space-y-4">
                                <% if (wishlist && wishlist.length > 0) { %>
                                    <% wishlist.forEach(function(movie) { %>
                                        <% 
                                            const posterUrl = movie.poster_path 
                                                ? (String(movie.poster_path).startsWith('http') 
                                                    ? movie.poster_path 
                                                    : ('https://image.tmdb.org/t/p/w200' + movie.poster_path))
                                                : '/static/images/no-poster.jpg';
                                        %>
                                        <a href="/movie/detail?id=<%= movie._id %>" class="flex items-center gap-4 group p-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5 hover:border-white/20 transition-all">
                                            <div class="w-12 h-16 flex-shrink-0 rounded-lg overflow-hidden relative bg-gray-800">
                                                <img src="<%= posterUrl %>" 
                                                     alt="<%= movie.title || movie.name %>" 
                                                     class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                                     onerror="this.src='/static/images/no-poster.jpg'">
                                            </div>
                                            <div class="flex-grow min-w-0">
                                                <h4 class="font-bold text-white text-sm truncate group-hover:text-primary transition-colors"><%= movie.title || movie.name %></h4>
                                                <p class="text-xs text-gray-400 mt-1">
                                                    <%= movie.media_type === 'tv' ? 'Phim bộ' : 'Phim lẻ' %> • <%= movie.release_date ? movie.release_date.substring(0, 4) : (movie.first_air_date ? movie.first_air_date.substring(0, 4) : 'N/A') %>
                                                </p>
                                            </div>
                                        </a>
                                    <% }); %>
                                <% } else { %>
                                    <div class="text-center py-8">
                                        <span class="material-symbols-outlined text-4xl text-gray-600 mb-2">movie_filter</span>
                                        <p class="text-gray-400 text-sm">Chưa có phim</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Continue Watching Section -->
                <div class="mt-12">
                    <h3 class="font-bold text-2xl text-white mb-6 flex items-center gap-3">
                        <span class="w-1 h-8 bg-red-600 rounded-full block"></span>
                        Tiếp tục xem
                    </h3>
                    
                    <% if (typeof watchHistory !== 'undefined' && watchHistory.length > 0) { %>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                            <% watchHistory.slice(0, 4).forEach(function(movie) { %>
                                <a href="/movie/detail?id=<%= movie._id %>" class="group relative aspect-video rounded-xl overflow-hidden bg-gray-900 border border-white/5 hover:border-white/20 transition-all">
                                    <!-- Backdrop Image -->
                                    <img src="https://image.tmdb.org/t/p/w500<%= movie.backdrop_path || movie.poster_path %>" 
                                         alt="<%= movie.title %>" 
                                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 opacity-60 group-hover:opacity-100"
                                         onerror="this.src='/static/images/no-backdrop.jpg'">
                                    
                                    <!-- Overlay Gradient -->
                                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>
                                    
                                    <!-- Content -->
                                    <div class="absolute bottom-0 left-0 right-0 p-4">
                                        <h4 class="font-bold text-white text-lg truncate mb-1 group-hover:text-primary transition-colors"><%= movie.title %></h4>
                                        
                                        <!-- Fake Progress Bar -->
                                        <div class="w-full h-1 bg-white/20 rounded-full mt-3 overflow-hidden">
                                            <div class="h-full bg-red-600 w-1/3 rounded-full"></div>
                                        </div>
                                        <div class="flex justify-between items-center mt-2">
                                            <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-red-600 transition-colors">
                                                <span class="material-symbols-outlined text-sm text-white">play_arrow</span>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="glass-panel p-12 rounded-2xl border border-white/5 text-center">
                            <span class="material-symbols-outlined text-5xl text-gray-700 mb-4">history</span>
                            <h4 class="text-xl font-bold text-gray-500 mb-2">Chưa có lịch sử xem</h4>
                            <p class="text-gray-500 mb-6">Các phim bạn xem sẽ xuất hiện tại đây</p>
                            <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary hover:bg-red-700 text-white font-bold transition-all">
                                <span class="material-symbols-outlined">explore</span>
                                Khám phá ngay
                            </a>
                        </div>
                    <% } %>
                </div>

            </div>
        </main>

        <%- include('partical/footer'); %>
    </div>
</body>
</html>