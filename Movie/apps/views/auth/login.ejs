<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <%- include('../partical/header'); %>
    <title>StreamLine - Login</title>
</head>
<body class="font-display bg-background-dark text-white min-h-screen flex flex-col antialiased selection:bg-primary selection:text-white">
    
    <div class="fixed inset-0 z-0">
        <div class="absolute inset-0 bg-[url('https://lh3.googleusercontent.com/aida-public/AB6AXuAcQVFNPS3mjbzevlQ-Y3JtwcWCP60vPM9m--EEd3nDXn78EvRMwlMaZkMp1ykHbKSp4BITN5S4CYm4lQ6ArqF2Tb-Z3giyBANF4kJvwq5Sq09TGEPjbDQm6VOOECrbKKHO5cOiEnSLEAAvki0_YXbaQ8In1ZWSNQchZwQ4oPktNAz8UqRM24dfKyIhKgCUbBl7wCg1Pp2cftVCy6BUYLOJzRnGEvMmZ5M8CripddCVaH2UhV5t1N9rjdD95Z4SpiL34pimEf5H4zA')] bg-cover bg-center opacity-40"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-background-dark via-background-dark/80 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-background-dark via-transparent to-background-dark"></div>
        <div class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-primary/10 blur-[100px]"></div>
        <div class="absolute bottom-1/4 right-1/4 h-96 w-96 rounded-full bg-accent-glow/10 blur-[100px]"></div>
    </div>
    <main class="relative z-10 flex flex-1 flex-col items-center justify-center px-4 py-20 min-h-[calc(100vh-80px)]">
        <div class="glass-panel cinematic-glow w-full max-w-[440px] rounded-2xl p-8 sm:p-10 relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary to-transparent opacity-50"></div>
            <div class="mb-8 text-center space-y-2">
                <h1 class="text-3xl font-bold tracking-tight text-white drop-shadow-lg">Chào mừng trở lại</h1>
                <p class="text-sm text-gray-400 font-medium">Đắm mình trong thế giới giải trí vô tận.</p>
                <% if (message) { %>
                    <div class="mt-4 p-3 bg-red-900/50 border border-red-500/50 rounded-lg text-red-200 text-sm">
                        <%= message %>
                    </div>
                <% } %>
            </div>
            <form class="flex flex-col gap-6" action="/auth/login" method="POST">
                <div class="space-y-2">
                    <label class="text-xs font-bold uppercase tracking-wider text-gray-400 ml-1" for="email">Email hoặc Tên đăng nhập</label>
                    <div class="relative group/input">
                        <input class="input-glass w-full rounded-lg px-4 py-3.5 bg-gray-900/50 focus:bg-gray-900/80 text-white placeholder:text-gray-500 outline-none transition-all duration-300 border border-white/10 focus:border-primary/50" id="email" name="email" placeholder="Nhập email của bạn" type="email" required />
                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 group-focus-within/input:text-primary transition-colors">mail</span>
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="text-xs font-bold uppercase tracking-wider text-gray-400 ml-1" for="password">Mật khẩu</label>
                    <div class="relative group/input">
                        <input class="input-glass w-full rounded-lg px-4 py-3.5 bg-gray-900/50 focus:bg-gray-900/80 text-white placeholder:text-gray-500 outline-none transition-all duration-300 border border-white/10 focus:border-primary/50" id="password" name="password" placeholder="Nhập mật khẩu của bạn" type="password" required />
                        <button class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white transition-colors focus:outline-none" id="togglePassword" type="button">
                            <span class="material-symbols-outlined text-xl">visibility_off</span>
                        </button>
                    </div>
                    <div class="flex items-center justify-between mt-3 px-1">
                        <div class="flex items-center gap-2 cursor-pointer group">
                            <input type="checkbox" id="remember" class="w-4 h-4 rounded border-gray-600 bg-gray-700/50 text-primary focus:ring-primary focus:ring-offset-background-dark cursor-pointer">
                            <label for="remember" class="text-xs text-gray-400 group-hover:text-white transition-colors cursor-pointer select-none">Ghi nhớ đăng nhập</label>
                        </div>
                        <a class="text-xs font-medium text-accent-blue hover:text-white hover:underline transition-colors" href="#">Quên mật khẩu?</a>
                    </div>
                </div>
                <button class="mt-2 relative w-full overflow-hidden rounded-lg bg-primary py-3.5 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-primary/25 transition-all hover:bg-primary-hover hover:shadow-primary/40 active:scale-[0.98]" type="submit">
                    <span class="relative z-10 flex items-center justify-center gap-2">
                        Đăng Nhập
                        <span class="material-symbols-outlined text-lg">login</span>
                    </span>
                </button>
            </form>
            <div class="relative my-8 text-center">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-white/10"></div>
                </div>
                <span class="relative bg-[#16161f] px-3 text-xs text-gray-500 uppercase tracking-widest font-medium">Hoặc tiếp tục với</span>
            </div>
            <div class="flex items-center justify-center gap-6">
                <button class="flex h-12 w-12 items-center justify-center rounded-full bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all duration-300 group hover:scale-110">
                    <i class="fa-brands fa-google text-white/80 group-hover:text-white text-xl"></i>
                </button>
                <button class="flex h-12 w-12 items-center justify-center rounded-full bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all duration-300 group hover:scale-110">
                    <i class="fa-brands fa-facebook-f text-white/80 group-hover:text-white text-xl"></i>
                </button>
                <button class="flex h-12 w-12 items-center justify-center rounded-full bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all duration-300 group hover:scale-110">
                     <i class="fa-brands fa-apple text-white/80 group-hover:text-white text-xl"></i>
                </button>
            </div>
            <p class="mt-8 text-center text-sm text-gray-400">
                Mới tham gia StreamLine? <a class="font-bold text-white hover:text-accent-blue transition-colors" href="/auth/register">Đăng ký ngay</a>
            </p>
        </div>
    </main>
    <%- include('../partical/footer'); %>
    <script>
        const passwordInput = document.getElementById('password');
        const toggleBtn = document.getElementById('togglePassword');
        const toggleIcon = toggleBtn.querySelector('.material-symbols-outlined');
        toggleBtn.addEventListener('click', () => {
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.textContent = 'visibility';
                toggleIcon.classList.add('text-primary'); 
            } else {
                passwordInput.type = 'password';
                toggleIcon.textContent = 'visibility_off';
                toggleIcon.classList.remove('text-primary');
            }
        });
    </script>
</body>
</html>