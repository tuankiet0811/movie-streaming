                                else if (tAvg != null) comb = tAvg;
                            %><%= comb != null ? comb.toFixed(1) : 'N/A' %></span>
                        </div>
                    </div>
                </a>
            <% }); %>
        </div>
        <div id="trending-group-1" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 hidden">
            <% chunk2.forEach(function(item){ %>
                <a href="/movie/detail?id=<%= item._id %>" class="group relative block rounded-xl overflow-hidden bg-surface border border-white/5 hover:border-white/20 transition-all shadow-2xl">
                    <div class="aspect-[2/3] w-full overflow-hidden">
                        <img alt="Poster phim <%= item.title %>" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" src="<%= (item.poster_path && item.poster_path.startsWith('http')) ? item.poster_path : 'https://image.tmdb.org/t/p/w500' + item.poster_path %>"/>
                    </div>
                    <div class="p-3">
                        <h3 class="text-sm font-bold truncate group-hover:text-primary transition-colors"><%= item.title %></h3>
                        <div class="flex items-center gap-2 text-[11px] font-medium text-gray-400 mt-1">
                            <span class="px-1.5 py-0.5 rounded bg-white/10 border border-white/5 text-gray-300"><%= item.adult ? '18+' : '13+' %></span>
                            <% 
                                var gName = '';
                                if (item.genre_ids && item.genre_ids.length > 0 && typeof allGenres !== 'undefined') {
                                    var g = allGenres.find(gg => gg._id.toString() === item.genre_ids[0].toString());
                                    gName = g ? g.Name : '';
                                }
                            %>
                            <span><%= gName %></span>
                            <span class="text-primary">•</span>
                            <span class="text-green-400 font-bold"><i class="fa-solid fa-star text-[10px]"></i> <% 
                                var rs = (typeof ratingStatsMap !== 'undefined' && ratingStatsMap && ratingStatsMap[item._id]) ? ratingStatsMap[item._id] : null;
                                var uAvg = rs ? Number(rs.average) : null;
                                var tAvg = item.vote_average ? Number(item.vote_average) : null;
                                var comb = null;
                                if (uAvg != null && tAvg != null) comb = (uAvg + tAvg)/2;
