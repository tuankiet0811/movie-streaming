        <script>
            let currentTrendingGroup = 0;
            function toggleTrending(direction){
                const next = Math.max(0, Math.min(1, currentTrendingGroup + direction));
                if (next === currentTrendingGroup) return;
                document.getElementById('trending-group-' + currentTrendingGroup).classList.add('hidden');
                document.getElementById('trending-group-' + next).classList.remove('hidden');
                currentTrendingGroup = next;
            }
