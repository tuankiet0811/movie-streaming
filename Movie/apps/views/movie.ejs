<!DOCTYPE html>
<html class="dark" lang="vi">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <%- include('partical/header'); %>
  <title><%= title || 'Danh sách phim' %> - StreamLine</title>
</head>

<body
  class="bg-brand-dark text-gray-200 font-display min-h-screen selection:bg-brand-red selection:text-white overflow-x-hidden">
  <%- include('partical/menu'); %>
  <main class="w-full px-4 sm:px-6 lg:px-10 pt-24 pb-12">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-baseline gap-4 mb-8">
        <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-white">Danh sách phim</h1>
        <div class="h-px w-12 bg-primary/50 self-center hidden sm:block"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-6">
        <% if (Array.isArray(items) && items.length) { %>
          <% items.forEach(function(item){ %>
            <div class="group relative rounded-xl overflow-hidden bg-surface border border-white/5 hover:border-white/20 transition-all shadow-2xl">
              <a href="/movie/detail?id=<%= item._id %>" class="block">
                <div class="aspect-[2/3] relative overflow-hidden">
                  <% 
                    const posterUrl = item.poster_path ? (item.poster_path.startsWith('http') ? item.poster_path : 'https://image.tmdb.org/t/p/w500' + item.poster_path) : 'https://via.placeholder.com/300x450?text=No+Poster';
                  %>
                  <img src="<%= posterUrl %>" alt="<%= item.title %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
              </a>
              <div class="p-3">
                <h3 class="text-sm font-bold truncate group-hover:text-primary transition-colors" title="<%= item.title %>"><%= item.title %></h3>
                <div class="flex items-center gap-2 text-[11px] font-medium text-gray-400 mt-1">
                  <span class="px-1.5 py-0.5 rounded bg-white/10 border border-white/5 text-gray-300"><%= item.adult ? '18+' : '13+' %></span>
                  <% 
                    var gName = '';
                    if (item.genre_ids && item.genre_ids.length > 0 && typeof allGenres !== 'undefined') {
                      var g = allGenres.find(gg => gg._id.toString() === item.genre_ids[0].toString());
                      gName = g ? g.Name : '';
                    }
                  %>
                  <span class="truncate max-w-[100px]"><%= gName %></span>
                  <span class="text-primary">•</span>
                  <span class="text-yellow-400 font-bold"><i class="fa-solid fa-star text-[10px]"></i> <% 
                    var rs = (typeof ratingStatsMap !== 'undefined' && ratingStatsMap && ratingStatsMap[item._id]) ? ratingStatsMap[item._id] : null;
                    var uAvg = rs ? Number(rs.average) : null;
                    var tAvg = item.vote_average ? Number(item.vote_average) : null;
                    var comb = null;
                    if (uAvg != null && tAvg != null) comb = (uAvg + tAvg)/2;
                    else if (uAvg != null) comb = uAvg;
                    else if (tAvg != null) comb = tAvg;
                  %><%= comb != null ? comb.toFixed(1) : 'N/A' %></span>
                  <span class="text-primary">•</span>
                  <span class="text-gray-300"><%= item.release_date ? new Date(item.release_date).getFullYear() : '' %></span>
                </div>
                <a href="/movie/detail?id=<%= item._id %>" class="mt-3 w-full inline-flex items-center justify-center h-9 rounded-lg bg-primary/90 text-white text-xs font-bold hover:bg-primary transition-colors">
                  Xem chi tiết
                </a>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-span-full text-center py-12 text-gray-400">
            <span class="material-symbols-outlined text-6xl mb-4">movie_off</span>
            <p>Chưa có phim nào được cập nhật.</p>
          </div>
        <% } %>
      </div>
      <% if (totalPages > 1) { %>
      <div class="mt-12 flex justify-center gap-2">
        <% for(let i = 1; i <= totalPages; i++) { %>
          <a href="/movie?page=<%= i %>" class="px-4 py-2 rounded-lg <%= currentPage == i ? 'bg-primary text-white' : 'bg-white/10 text-gray-300 hover:bg-white/20' %> transition-colors">
            <%= i %>
          </a>
        <% } %>
      </div>
      <% } %>
    </div>
  </main>
  <% if(false) { %><div class="max-w-7xl mx-auto px-6 mt-8 mb-24 relative z-10">
